  "license": "MIT",
  "homepage": "https://github.com/52-entertainment/vite-plugin-oxlint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/52-entertainment/vite-plugin-oxlint.git"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
